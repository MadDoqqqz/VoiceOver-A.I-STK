rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // USER RULES
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && incoming().plan == 'free' // Force free plan on creation
        && incoming().uid == request.auth.uid
        && incoming().email == request.auth.token.email;
      allow update: if isOwner(userId)
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt'])
        && incoming().updatedAt == request.time;
    }

    // VOICE RULES
    function isValidVoice(data) {
      return data.ownerId == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.status in ['training', 'active', 'failed'];
    }

    match /voices/{voiceId} {
      allow get: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(voiceId) && isValidVoice(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isOwner(existing().ownerId)
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'status'])
        && (incoming().status == existing().status || incoming().status in ['active', 'failed']);
      allow delete: if isSignedIn() && isOwner(existing().ownerId);
    }

    // HISTORY RULES
    function isValidHistory(data) {
      return data.ownerId == request.auth.uid
        && data.voiceId is string && data.voiceId.size() <= 128
        && data.text is string && data.text.size() <= 5000
        && data.audioUrl is string && data.audioUrl.size() <= 1000;
    }

    match /history/{audioId} {
      allow get: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(audioId) && isValidHistory(incoming()) && incoming().createdAt == request.time;
      allow delete: if isSignedIn() && isOwner(existing().ownerId);
    }
  }
}
